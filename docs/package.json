{
  "name": "is-kit-docs",
  "private": true,
  "version": "1.0.0",
  "description": "Documentation site for is-kit (Next.js + shadcn)",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm --workspace-root run build && next build",
    "start": "next start",
    "lint": "pnpm --workspace-root exec oxlint docs",
    "shadcn:init": "pnpm dlx shadcn@latest init",
    "shadcn:add": "pnpm dlx shadcn@latest add",
    "shadcn:list": "pnpm dlx shadcn@latest list"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "is-kit": "workspace:*",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/postcss": "^4.3.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
