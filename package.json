{
  "name": "is-kit",
  "version": "1.11.4",
  "description": "Zero-dependency TypeScript runtime validation toolkit for composable type guards and natural type narrowing.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "is-kit": "./bin/is-kit.mjs"
  },
  "scripts": {
    "test": "jest",
    "test:types": "tsd",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "build": "tsup",
    "typedoc": "typedoc --out docs/public/api"
  },
  "keywords": [
    "typescript",
    "type-guard",
    "type-guards",
    "runtime-validation",
    "validation",
    "validator",
    "type-safety",
    "type-narrowing",
    "unknown",
    "schema",
    "zero-dependency"
  ],
  "files": [
    "bin",
    "dist",
    "docs/agent-rules.md",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyaomaru/is-kit.git"
  },
  "bugs": {
    "url": "https://github.com/nyaomaru/is-kit/issues"
  },
  "homepage": "https://is-kit-docs.vercel.app/",
  "author": "nyaomaru",
  "license": "MIT",
  "packageManager": "pnpm@11.2.2",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "ts-jest": "^29.4.11",
    "tsd": "^0.33.0",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "tsd": {
    "directory": "tests-d",
    "compilerOptions": {
      "baseUrl": ".",
      "ignoreDeprecations": "6.0"
    }
  }
}
